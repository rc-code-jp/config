#!/bin/bash

# 1) 引数で受け取ったフォルダを使う。未指定なら現在のディレクトリを使う
d="${1:-$PWD}"

# 2) VS Code でそのフォルダを開く
code "$d"

# 3) Ghostty もそのフォルダで開く
open -a Ghostty "$d"

# 4) AppleScript で VS Code を左60%、Ghostty を右40%に並べる
osascript -e '
tell application "System Events"
  -- デスクトップ全体の座標を取得
  set b to bounds of window of desktop

  -- 画面の右端座標を取得
  set screenRight to item 3 of b

  -- 60% の位置を計算
  set splitX to screenRight * 0.6

  -- VS Code を左60%に配置
  tell process "Code" to set bounds of front window to {0, 25, splitX, item 4 of b}

  -- Ghostty を右40%に配置
  tell process "Ghostty" to set bounds of front window to {splitX, 25, screenRight, item 4 of b}
end tell'