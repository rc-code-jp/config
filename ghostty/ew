#!/usr/bin/osascript

-- End Work ... 作業を終了してパネルを1つに戻す。
-- 新しいタブを開き、現在のタブの全ターミナルを閉じる。

tell application "Ghostty"
	activate

	try
		set win to front window
		set oldTab to selected tab of win

		-- 現在のディレクトリを引き継ぐ
		set cwd to working directory of focused terminal of oldTab

		-- 古いタブの全ターミナルのIDを収集
		set termIds to {}
		repeat with t in terminals of oldTab
			set end of termIds to id of t
		end repeat

		-- 新しいタブを現在のディレクトリで作成
		set cfg to new surface configuration
		set initial working directory of cfg to cwd
		new tab in win with configuration cfg
		delay 0.3

		-- 古いタブの全ターミナルを閉じる（タブも自動的に消える）
		repeat with tid in termIds
			try
				close terminal id tid
			end try
		end repeat

		-- 新しいタブのターミナルにフォーカス
		focus focused terminal of selected tab of win
	on error errMsg
		return errMsg
	end try
end tell
